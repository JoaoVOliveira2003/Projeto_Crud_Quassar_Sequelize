{
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2020",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
  "esModuleInterop": true,

    "outDir": "./dist",
    "rootDir": "./",
    "allowImportingTsExtensions": true,
    "noEmit": true

  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}